# Required Slack credentials
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# The Slack channel ID to monitor (right-click the channel → Copy link → last segment)
CHANNEL_ID=C0XXXXXXXXX

# Socket Mode (set to "true" if using Socket Mode instead of HTTP Events API)
# Requires SLACK_APP_TOKEN when enabled
SOCKET_MODE=false
# SLACK_APP_TOKEN=xapp-your-app-token-here

# Port the HTTP server listens on (Railway sets this automatically)
PORT=3000

# Seed the starting count if recovering from an existing channel
# (leave at 0 for a fresh channel)
INITIAL_COUNT=0

# Override the path used to persist bot state (default: data/state.json)
# STATE_FILE=/data/state.json
