# Slack Bot credentials — get these from https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# The Slack channel ID for #counttoamillion
# Right-click the channel in Slack → "Copy link" → the last path segment (e.g. C08XXXXXXXX)
CHANNEL_ID=C0XXXXXXXXX

# Socket Mode — set to "true" to use Socket Mode instead of HTTP Events API.
# Requires a separate App-Level Token (xapp-…) when enabled.
SOCKET_MODE=false
# SLACK_APP_TOKEN=xapp-your-app-token-here

# Port the HTTP server listens on (Railway injects this automatically)
PORT=3000

# Path to the SQLite database file (default: data/ctm.db)
# On Railway, point this at a Volume mount so the DB survives deploys:
# DB_FILE=/data/ctm.db
